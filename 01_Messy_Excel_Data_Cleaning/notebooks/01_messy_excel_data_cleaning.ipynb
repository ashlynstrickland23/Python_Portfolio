   "source": [
    "# Clean text fields\n",
    "\n",
    "clean_df[\"region\"] = (\n",
    "    clean_df[\"region\"]\n",
    "    .astype(\"string\")\n",
    "    .str.strip()\n",
    "    .str.title()\n",
    "    .replace({\"Nan\": \"Unknown\", \"<NA>\": \"Unknown\"})\n",
    "    .fillna(\"Unknown\")\n",
    ")\n",
    "\n",
    "clean_df[\"product_category\"] = (\n",
    "    clean_df[\"product_category\"]\n",
    "    .astype(\"string\")\n",
    "    .str.strip()\n",
    "    .str.title()\n",
    "    .replace({\n",
    "        \"Tech\": \"Technology\",\n",
    "        \"Furniture\": \"Furniture\",\n",
    "        \"Nan\": \"Unknown\",\n",
    "        \"<NA>\": \"Unknown\"\n",
    "    })\n",
    "    .fillna(\"Unknown\")\n",
    ")\n",
    "\n",
    "clean_df[\"sales_rep\"] = (\n",
    "    clean_df[\"sales_rep\"]\n",
    "    .astype(\"string\")\n",
    "    .str.strip()\n",
    "    .str.title()\n",
    "    .replace({\"Nan\": \"Unknown\", \"<NA>\": \"Unknown\"})\n",
    "    .fillna(\"Unknown\")\n",
    ")\n",
    "\n",
    "clean_df[\"status\"] = (\n",
    "    clean_df[\"status\"]\n",
    "    .astype(\"string\")\n",
    "    .str.strip()\n",
    "    .str.title()\n",
    "    .replace({\n",
    "        \"Complete\": \"Completed\",\n",
    "        \"Nan\": \"Unknown\",\n",
    "        \"<NA>\": \"Unknown\"\n",
    "    })\n",
    "    .fillna(\"Unknown\")\n",
    ")\n",
    "\n",
    "clean_df.head()"
   ]
  },
